# Shared Supabase (create a project in Supabase, then fill these in)
EXPO_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_KEY"

# Web-only (Next.js)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"
APP_ORIGIN="http://localhost:3000"

# Optional for /api/vision-scan (Google Cloud Vision)
GOOGLE_VISION_API_KEY="YOUR_GOOGLE_VISION_API_KEY"
ENABLE_VISION_SCAN="false"
VISION_SCAN_RATE_LIMIT_WINDOW_MS="60000"
VISION_SCAN_RATE_LIMIT_MAX="20"
VISION_SCAN_MAX_IMAGE_BYTES="4000000"
