{
  "name": "om-library-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm -w @om/web run dev",
    "dev:web:turbo": "npm -w @om/web run dev:turbo",
    "dev:mobile": "npm -w @om/mobile run dev",
    "install:web": "npm install -w @om/shared -w @om/web",
    "build:web": "npm -w @om/web run build",
    "typecheck": "npm --workspaces run typecheck"
  }
}
